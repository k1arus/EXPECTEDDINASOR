<Window x:Class="Redscreen.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SchoolTimerWindow"
        WindowState="Maximized"
        WindowStyle="None"
        Background="Black"
        KeyDown="Window_KeyDown"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Grid>

        <TextBlock
            x:Name="TimerText"
            Text="05:00"
            Foreground="#FF2A2A"
            FontWeight="Bold"
            FontSize="220"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"/>

        <TextBlock
            x:Name="MessageText"
            Text="クリックして開始"
            Foreground="White"
            FontSize="28"
            HorizontalAlignment="Center"
            VerticalAlignment="Bottom"
            Margin="0,0,0,80"/>

        <Button
            x:Name="ResetButton"
            Content="リセット"
            Width="250"
            Height="90"
            FontSize="32"
            Visibility="Collapsed"
            HorizontalAlignment="Center"
            VerticalAlignment="Bottom"
            Margin="0,0,0,80"
            Click="ResetButton_Click"/>

    </Grid>

</Window>